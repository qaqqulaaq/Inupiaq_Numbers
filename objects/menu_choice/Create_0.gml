switch say {
	case "Number Conversions":
		x = room_width * 3 div 4
		y = room_height * 2 div 5
		break;
		
	case "Number Operations":

		x = room_width div 4
		y = room_height * 2 div 5
		break;
		
	case "Numbers to Words":

		x = room_width div 2
		y = room_height * 3 div 5
		break;
		
	case "Word Building\nVocabulary":

		x = room_width * 3 div 4
		y = room_height * 4 div 5
		break;
		
	case "Multiple Choice\nVocabulary":

		x = room_width div 4
		y = room_height * 4 div 5
		break;
}

alpha = 0
col = 255